# ============================================
# DataSphere Innovation - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="DataSphere Innovation"

# ==========================================
# DATABASE
# ==========================================
# SQLite (Development)
DATABASE_URL="file:./dev.db"

# PostgreSQL (Production)
# DATABASE_URL="postgresql://user:password@localhost:5432/dataspheir?schema=public"

# ==========================================
# AUTHENTICATION (NextAuth.js)
# ==========================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-this-in-production

# ==========================================
# STRIPE PAYMENT
# ==========================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ==========================================
# SSO PROVIDERS (Enterprise)
# ==========================================
# Microsoft Azure AD / Entra ID
# AZURE_AD_CLIENT_ID=your-azure-client-id
# AZURE_AD_CLIENT_SECRET=your-azure-client-secret
# AZURE_AD_TENANT_ID=your-tenant-id

# Google Workspace
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Okta
# OKTA_CLIENT_ID=your-okta-client-id
# OKTA_CLIENT_SECRET=your-okta-client-secret
# OKTA_ISSUER=https://your-domain.okta.com/oauth2/default

# Auth0
# AUTH0_CLIENT_ID=your-auth0-client-id
# AUTH0_CLIENT_SECRET=your-auth0-client-secret
# AUTH0_ISSUER=https://your-tenant.auth0.com

# ==========================================
# AI SDK (z-ai-web-dev-sdk)
# ==========================================
ZAI_API_KEY=your-zai-api-key

# ==========================================
# REDIS (Optional - for caching and sessions)
# ==========================================
# REDIS_URL=redis://localhost:6379

# ==========================================
# EMAIL SERVICE (Transactional Emails)
# ==========================================
# Email Provider: 'resend' or 'sendgrid'
EMAIL_PROVIDER=resend

# Resend API (Recommended - https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid API (Alternative - https://sendgrid.com)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email Configuration
EMAIL_FROM=noreply@datasphere-innovation.fr
EMAIL_FROM_NAME="DataSphere Innovation"
EMAIL_REPLY_TO=support@datasphere-innovation.fr

# Email API Key (for internal API authentication)
EMAIL_API_KEY=your-email-api-key-for-internal-use

# Email Queue Settings
EMAIL_QUEUE_MAX_ATTEMPTS=5
EMAIL_QUEUE_CONCURRENCY=5
EMAIL_QUEUE_PROCESS_INTERVAL=5000

# Email Rate Limiting (per recipient)
EMAIL_RATE_LIMIT_MAX=100
EMAIL_RATE_LIMIT_WINDOW_MS=60000

# ==========================================
# MONITORING & LOGGING
# ==========================================
# Sentry - Error Tracking & Performance Monitoring
# Required: NEXT_PUBLIC_SENTRY_DSN for basic functionality
# Required for source maps upload: SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o1234567.ingest.sentry.io/1234567
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-organization-slug
SENTRY_PROJECT=your-project-slug
# Optional: Set a custom release version
# SENTRY_RELEASE=1.0.0

# LogRocket
# NEXT_PUBLIC_LOGROCKET_APP_ID=your-logrocket-app-id

# ==========================================
# ANALYTICS
# ==========================================
# Mixpanel
# NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# Google Analytics
# NEXT_PUBLIC_GA_ID=UA-XXXXXXXXX-X

# ==========================================
# SECURITY
# ==========================================
# Encryption key for sensitive data (32 bytes hex)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ==========================================
# FEATURES FLAGS
# ==========================================
NEXT_PUBLIC_ENABLE_SSO=false
NEXT_PUBLIC_ENABLE_BILLING=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# ==========================================
# EXTERNAL APIS
# ==========================================
# BigQuery
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_KEYFILE=path/to/service-account.json

# Snowflake
# SNOWFLAKE_ACCOUNT=your-account
# SNOWFLAKE_USER=your-user
# SNOWFLAKE_PASSWORD=your-password
# SNOWFLAKE_DATABASE=your-database
# SNOWFLAKE_SCHEMA=your-schema
